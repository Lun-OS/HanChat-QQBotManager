
# 服务器配置
SERVER_PORT=59178
SERVER_HOST=0.0.0.0
SERVER_CORS_ENABLED=true
SERVER_CORS_ORIGIN=*

# ========== Web登录系统配置（替代MySQL） ==========
# 登录用户名
WEB_LOGIN_USER=admin
# 登录密码
WEB_LOGIN_PWD=1596534228
# 时区偏移，默认UTC+8（北京时间）
TIMEZONE_OFFSET=8

# ========== 反向WebSocket配置 ==========
# 全局统一Token（用于反向WS鉴权，为空则不鉴权）
WEBSOCKET_AUTHORIZATION=
# 反向WS监听端口（推荐使用SERVER_PORT)
# WEBSOCKET_PORT=8765
# 最大机器人连接数限制
WEBSOCKET_MAX_CONNECTIONS=10

# ========== 日志配置 ==========
LOGGER_LEVEL=info
LOGGER_FORMAT=json
LOGGER_COLORIZE=true
LOGGER_MAX_FILES=14d
LOGGER_MAX_SIZE=20m
LOGGER_DIR=./logs

# ========== 插件配置 ==========
PLUGIN_WORKERS=8
PLUGIN_QUEUE_SIZE=1024
